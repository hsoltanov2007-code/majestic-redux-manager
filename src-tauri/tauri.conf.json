{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hardy MODS",
  "version": "0.1.58",
  "identifier": "com.hardy.mods",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "Hardy MODS",
        "width": 1450,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],

    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,

    "resources": [
      "resources/rpf-unlocker/rpf_unlock_tool.exe",
      "resources/rpf-unlocker/rpf_unlock_tool.dll",
      "resources/rpf-unlocker/rpf_unlock_tool.deps.json",
      "resources/rpf-unlocker/rpf_unlock_tool.runtimeconfig.json",

      "resources/rpf-unlocker/keys/gtav_aes_key.dat",
      "resources/rpf-unlocker/keys/gtav_hash_lut.dat",
      "resources/rpf-unlocker/keys/gtav_ng_decrypt_tables.dat",
      "resources/rpf-unlocker/keys/gtav_ng_encrypt_luts.dat",
      "resources/rpf-unlocker/keys/gtav_ng_encrypt_tables.dat",
      "resources/rpf-unlocker/keys/gtav_ng_key.dat",

      "resources/rpf-explorer/HardyRpfExplorer.exe"
    ],

    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },

  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hardy-mods"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCMEIxOEJBQUU5REMzNDMKUldSRHc1MnV1aGdMZTJYRnJSSEhoYk9IQ0MreFo0bS84WFJGV1Ewc2J6STNZaHRCYUtwTEZuM0kK",
      "endpoints": [
        "https://github.com/hsoltanov2007-code/majestic-redux-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
